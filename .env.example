# Copy to .env.local and fill in. NEVER commit .env.local — it is gitignored.

# Exa API key — required. Get one at https://dashboard.exa.ai/
EXA_API_KEY=

# Google Gemini API key — required. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# PostHog (product analytics). Public keys; analytics is a no-op without them.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional — abuse / cost control. Without these, a best-effort in-memory
# limiter is used per instance. Configure Upstash Redis for a durable global cap.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Max uncached report builds per UTC day (kill switch). Defaults to 500.
DAILY_REPORT_BUDGET=500

# Hybrid backend: set to "1" to power the emerging / under-the-radar discovery
# with Exa Agent (deep research) instead of the fast freshness search. Off by
# default so the streaming search path stays the demo-safe spine. Falls back to
# search automatically if Agent returns nothing.
EXA_AGENT_EMERGING=0
